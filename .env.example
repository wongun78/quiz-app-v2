# =============================================================================
# .env.example — Template cho deploy.sh
# Sao chép: cp .env.example .env  →  điền giá trị thật
# .env đã có trong .gitignore → KHÔNG bị commit
# =============================================================================

# PostgreSQL password cho user 'postgres' (dùng bởi deploy.sh)
DB_PASSWORD=your-strong-db-password-here

# JWT signing secret — tối thiểu 32 ký tự (dùng bởi deploy.sh)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long-here

# Tài khoản admin mặc định (seed lúc app khởi động lần đầu)
ADMIN_PASSWORD=your-admin-password-here

# Tài khoản user mặc định
USER_PASSWORD=your-user-password-here
